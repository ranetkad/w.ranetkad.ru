&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">curl -fO https://ftp.ripe.net/ripe/atlas/software-probe/&lt;span class="s2">&amp;#34;&lt;/span>&lt;span class="nv">$EL_VER&lt;/span>&lt;span class="s2">&amp;#34;&lt;/span>/noarch/ripe-atlas-repo-1.5-5.&lt;span class="s2">&amp;#34;&lt;/span>&lt;span class="nv">$EL_VER&lt;/span>&lt;span class="s2">&amp;#34;&lt;/span>.noarch.rpm
