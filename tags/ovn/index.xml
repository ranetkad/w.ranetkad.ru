&lt;a href="#%d1%82%d0%b5%d1%80%d0%bc%d0%b8%d0%bd%d1%8b" class="subheading-anchor" aria-label="Постоянная ссылка на этот раздел">&lt;/a>&lt;/h2>&lt;table>
&lt;thead>
&lt;tr>
&lt;th>&lt;/th>
&lt;th>&lt;/th>
&lt;/tr>
&lt;/thead>
&lt;tbody>
&lt;tr>
&lt;td>Logical Switch&lt;/td>
&lt;td>виртуальный L2 segment, multi-host&lt;/td>
&lt;/tr>
&lt;tr>
&lt;td>Logical Router&lt;/td>
&lt;td>distributed router, logical&lt;/td>
&lt;/tr>
&lt;tr>
&lt;td>Chassis&lt;/td>
&lt;td>hypervisor с ovn-controller&lt;/td>
&lt;/tr>
&lt;tr>
&lt;td>Port Binding&lt;/td>
&lt;td>привязка logical port к chassis&lt;/td>
&lt;/tr>
&lt;tr>
&lt;td>Localnet&lt;/td>
&lt;td>L2 attachment к физической сети через bridge mapping&lt;/td>
&lt;/tr>
&lt;tr>
&lt;td>Geneve&lt;/td>
&lt;td>default tunnel encapsulation между chassis&lt;/td>
&lt;/tr>
&lt;/tbody>
&lt;/table>
&lt;h2>Команды&lt;span class="hx:absolute hx:-mt-20" id="команды">&lt;/span>
&lt;a href="#%d0%ba%d0%be%d0%bc%d0%b0%d0%bd%d0%b4%d1%8b" class="subheading-anchor" aria-label="Постоянная ссылка на этот раздел">&lt;/a>&lt;/h2>&lt;div class="hextra-code-block hx:relative hx:mt-6 hx:first:mt-0 hx:group/code">
&lt;div>&lt;pre>&lt;code>ovn-nbctl ls-list / ls-add / ls-del
ovn-nbctl lr-list / lr-add / lr-del
ovn-nbctl lsp-add / lsp-set-addresses
ovn-sbctl show
ovn-sbctl chassis-list
ovn-trace --detailed &amp;lt;ls&amp;gt; &amp;lt;flow&amp;gt;&lt;/code>&lt;/pre>&lt;/div>&lt;div class="hextra-code-copy-btn-container hx:opacity-0 hx:transition hx:group-hover/code:opacity-100 hx:flex hx:gap-1 hx:absolute hx:m-[11px] hx:right-0 hx:top-0">
